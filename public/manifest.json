{
    "manifest_version": 3,
    "name": "Chrodachi",
    "description": "How long have I been on google?",
    "version": "1.0",
    "icons": {
        "19": "assets/browser-action/action-19.png",
        "38": "assets/browser-action/action-38.png"
    },
    "action": {},
    "side_panel": {
        "default_path": "popup.html"
    },
    "background": {
        "service_worker": "service.js",
        "type": "module"
    },
    "permissions": [
        "storage",
        "alarms",
        "notifications",
        "system.memory",
        "sidePanel"
    ]
}
